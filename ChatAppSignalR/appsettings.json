{
    "MongoDbSettings": {
        "ConnectionString": "mongodb://localhost:27017",
        "DatabaseName": "ChatAppDb",
        "UsersCollectionName": "Users",
        "RefreshTokensCollectionName": "RefreshTokens",
        "FriendsCollectionName": "Friends",
        "ConversationsCollectionName": "Conversations",
        "MessagesCollectionName": "Messages"
    },
    "Jwt": {
        "Issuer": "ChatApp",
        "Audience": "ChatAppUsers",
        "Key": "your_super_secret_key_123456789"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}